digraph BlockDesign {
    rankdir=LR;
    node [shape=record, style=filled, fillcolor=lightblue, fontname="Courier"];
    edge [fontname="Courier", fontsize=10];
    splines=ortho;

  subgraph cluster_riscv_core {
      label="riscv_core (top)";
    style=filled;
    fillcolor=lightyellow;
    color=blue if is_top else "black";
    u_alu [label="{<a> a | <b> b | <op> op | <result> result} | u_alu"];
    u_special_32bit [label="u_special_32bit"];
    top_inputs [label="{<clk> clk | <rst_n> rst_n | <inst_mem_data> inst_mem_data} | Inputs", shape=box, fillcolor=lightgreen];
    top_outputs [label="Outputs | {<inst_mem_addr> inst_mem_addr}", shape=box, fillcolor=lightcoral];
  }

    "pc_current" -> u_alu:a [label="a"];
    "32'h4" -> u_alu:b [label="b"];
    "alu_op" -> u_alu:op [label="op"];
    "alu_result" -> u_alu:result [label="result"];
    "pc_current" -> "inst_mem_addr" [label="assign", style=dashed, color=green];
}